# ═══════════════════════════════════════════════════════════════════════════════
# NEXUS ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────────
POSTGRES_USER="nexus"
POSTGRES_PASSWORD="REPLACE_WITH_STRONG_POSTGRES_PASSWORD"
POSTGRES_DB="nexus_db"
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}?schema=public"

# ─────────────────────────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# ─────────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION
# ─────────────────────────────────────────────────────────────────────────────────
JWT_SECRET="REPLACE_WITH_RANDOM_64_CHAR_SECRET"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_RANDOM_64_CHAR_SECRET"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─────────────────────────────────────────────────────────────────────────────────
# API SERVER
# ─────────────────────────────────────────────────────────────────────────────────
API_PORT=4000
API_HOST="0.0.0.0"
API_URL="http://localhost:4000"
CORS_ORIGINS="http://localhost:3000"

# ─────────────────────────────────────────────────────────────────────────────────
# NEXT.JS WEB APP
# ─────────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"

# ─────────────────────────────────────────────────────────────────────────────────
# FILE STORAGE (S3-compatible)
# ─────────────────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER="REPLACE_WITH_MINIO_ROOT_USER"
MINIO_ROOT_PASSWORD="REPLACE_WITH_STRONG_MINIO_ROOT_PASSWORD"
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="${MINIO_ROOT_USER}"
S3_SECRET_KEY="${MINIO_ROOT_PASSWORD}"
S3_BUCKET="nexus-media"
S3_REGION="us-east-1"
CDN_URL="http://localhost:9000/nexus-media"

# ─────────────────────────────────────────────────────────────────────────────────
# AI & MODERATION
# ─────────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=""
PERSPECTIVE_API_KEY=""

# ─────────────────────────────────────────────────────────────────────────────────
# PAYMENTS (Stripe)
# ─────────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ─────────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT
# ─────────────────────────────────────────────────────────────────────────────────
NODE_ENV="development"
LOG_LEVEL="debug"
