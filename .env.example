# ═══════════════════════════════════════════════════════════════════════════════
# NEXUS ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://nexus:nexus_password@localhost:5432/nexus_db?schema=public"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─────────────────────────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# ─────────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION
# ─────────────────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-long-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars-change-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─────────────────────────────────────────────────────────────────────────────────
# API SERVER
# ─────────────────────────────────────────────────────────────────────────────────
API_PORT=4000
API_HOST="0.0.0.0"
API_URL="[localhost](http://localhost:4000)"
CORS_ORIGINS="[localhost](http://localhost:3000)"

# ─────────────────────────────────────────────────────────────────────────────────
# NEXT.JS WEB APP
# ─────────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="[localhost](http://localhost:4000)"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"
NEXT_PUBLIC_APP_URL="[localhost](http://localhost:3000)"
NEXTAUTH_URL="[localhost](http://localhost:3000)"
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"

# ─────────────────────────────────────────────────────────────────────────────────
# FILE STORAGE (S3-compatible)
# ─────────────────────────────────────────────────────────────────────────────────
S3_ENDPOINT="[localhost](http://localhost:9000)"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="nexus-media"
S3_REGION="us-east-1"
CDN_URL="[localhost](http://localhost:9000/nexus-media)"

# ─────────────────────────────────────────────────────────────────────────────────
# AI & MODERATION
# ─────────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=""
PERSPECTIVE_API_KEY=""

# ─────────────────────────────────────────────────────────────────────────────────
# PAYMENTS (Stripe)
# ─────────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ─────────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT
# ─────────────────────────────────────────────────────────────────────────────────
NODE_ENV="development"
LOG_LEVEL="debug"
