{
  "name": "nexus",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "sh -c '((lsof -ti:3000 2>/dev/null; lsof -ti:4000 2>/dev/null) | sort -u | xargs kill -9 2>/dev/null || true) && turbo run dev'",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:generate": "pnpm --filter database generate",
    "db:push": "echo 'db:push is disabled for safety. Use db:migrate or db:deploy instead.' && exit 1",
    "db:migrate": "pnpm --filter database migrate",
    "db:deploy": "pnpm --filter database deploy",
    "db:seed": "pnpm --filter database seed",
    "docker:dev": "docker-compose -f docker-compose.yml up -d",
    "docker:down": "docker-compose down",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.12.0",
    "prettier": "^3.2.0",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
